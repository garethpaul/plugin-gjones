{
  "name": "@garethpaul/plugin-gjones",
  "description": "Credential-free Twilio CLI plugin scaffold",
  "version": "1.0.0",
  "author": "@garethpaul",
  "bugs": "https://github.com/garethpaul/plugin-gjones/issues",
  "dependencies": {
    "@oclif/core": "^1.26.2",
    "@twilio/cli-core": "^8.3.4"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "files": [
    "/bin",
    "/oclif.manifest.json",
    "/src"
  ],
  "homepage": "https://github.com/garethpaul/plugin-gjones",
  "keywords": [
    "oclif-plugin"
  ],
  "license": "MIT",
  "oclif": {
    "name": "gjones",
    "commands": "./src/commands",
    "bin": "twilio",
    "repositoryPrefix": "<%- repo %>/blob/<%- version %>/<%- commandPath %>",
    "devPlugins": [
      "@oclif/plugin-help"
    ],
    "topics": {
      "gjones": {
        "description": "just my simple plugin"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/garethpaul/plugin-gjones.git"
  },
  "scripts": {
    "build": "npm run check",
    "check": "node scripts/check-baseline.js",
    "lint": "npm run check",
    "postpack": "node -e \"require('fs').rmSync('oclif.manifest.json', {force: true})\"",
    "prepack": "oclif manifest && oclif readme",
    "test": "npm run check && npm run test:command && npm run test:oclif",
    "test:command": "node tests/command-output.test.js",
    "test:oclif": "node tests/oclif-command-smoke.test.js",
    "version": "oclif readme && git add README.md"
  },
  "devDependencies": {
    "oclif": "^4.23.14"
  }
}
